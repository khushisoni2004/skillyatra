          <div className="mt-8 grid gap-4 md:grid-cols-4">
            <div className="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur-xl">
              <p className="text-sm font-bold text-indigo-100">Role Type</p>
              <h2 className="mt-2 text-xl font-black">{prep.category}</h2>
            </div>

            <div className="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur-xl">
              <p className="text-sm font-bold text-indigo-100">Package</p>
