            </h2>
            <p className="mt-2 text-sm font-semibold text-slate-500">
              YouTube links are generated from this role name and required skills in the dataset.
            </p>
          </div>
        </div>

        <div className="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {youtubeResources.map((item, index) => (
            <a
              key={`${item.title}-${index}`}
              href={item.url}
              target="_blank"
              rel="noreferrer"
              className="group rounded-[28px] border border-red-100 bg-gradient-to-br from-white via-red-50/40 to-indigo-50 p-5 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-red-100"
            >
