import React, { useEffect, useMemo, useState } from "react";
import { useNavigate, useParams } from "react-router-dom";

const API_BASE = import.meta.env.VITE_API_URL || "http://localhost:5001";



function uniqByTitle(list) {
  const seen = new Set();
  return (list || []).filter((item) => {
    const key = String(item.title || "").toLowerCase();
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
}

function hasAny(text, words) {
  return words.some((word) => text.includes(word));
}


function cleanSkill(skill) {
  return String(skill || "")
    .replace(/[^\w\s.+#/-]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function uniqueSkills(skills) {
  const seen = new Set();

  return (skills || [])
    .map(cleanSkill)
    .filter(Boolean)
    .filter((skill) => {
      const key = skill.toLowerCase();
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    });
}

function makeSearchUrl(base, query) {
  return `${base}${encodeURIComponent(query)}`;
}

function getRoleCategory(roleName, skills) {
  const role = String(roleName || "").trim();
  if (role) return role;
  const firstSkill = uniqueSkills(skills)[0];
  return firstSkill ? `${firstSkill} Role` : "Role Preparation";
}

function getPrepSuggestion(roleName, skills) {
  const role = String(roleName || "this role").trim();
  const skillList = uniqueSkills(skills).slice(0, 8);
  const topSkills = skillList.slice(0, 4);

  const easyPlan = [
    `Understand the ${role} job description and daily work.`,
    topSkills.length
      ? `First prepare: ${topSkills.join(", ")}.`
      : "First prepare the main required skills from the dataset.",
    "Make short notes and practice examples for each skill.",
    `Prepare interview answers around ${role}, projects and required skills.`
  ];

  const studyPlan = topSkills.length
    ? topSkills
    : ["Role basics", "Required skills", "Interview questions", "Resume explanation"];

  return {
    category: role,
    easyPlan,
    studyPlan
  };
}

function getResourceLinks(roleName, skills) {
  const role = String(roleName || "job role").trim();
  const skillList = uniqueSkills(skills).slice(0, 6);

  const resources = [];

  resources.push({
    title: `${role} interview preparation`,
    type: "GFG Search",
    url: makeSearchUrl("https://www.geeksforgeeks.org/search/?q=", `${role} interview preparation`)
  });

  skillList.forEach((skill) => {
    resources.push({
      title: `${skill} notes and interview questions`,
      type: "GFG Search",
      url: makeSearchUrl("https://www.geeksforgeeks.org/search/?q=", `${skill} interview questions`)
    });
  });

  resources.push({
    title: `${role} resume and interview questions`,
    type: "Google Search",
    url: makeSearchUrl("https://www.google.com/search?q=", `${role} resume interview questions required skills`)
  });

  return resources.slice(0, 8);
}

function getYoutubeResources(roleName, skills) {
  const role = String(roleName || "job role").trim();
  const skillList = uniqueSkills(skills).slice(0, 6);

  const videos = [];

  videos.push({
    title: `${role} complete preparation`,
    url: makeSearchUrl("https://www.youtube.com/results?search_query=", `${role} complete preparation`)
  });

  videos.push({
    title: `${role} interview questions`,
    url: makeSearchUrl("https://www.youtube.com/results?search_query=", `${role} interview questions`)
  });

  skillList.forEach((skill) => {
    videos.push({
      title: `${skill} preparation`,
      url: makeSearchUrl("https://www.youtube.com/results?search_query=", `${skill} tutorial interview preparation`)
    });
  });

  return videos.slice(0, 8);
}

export default function RoleDetail() {
  const navigate = useNavigate();
  const { companyName, roleId } = useParams();

  const decodedCompanyName = decodeURIComponent(companyName || "");
  const roleIndex = Number(roleId || 1) - 1;

  const [company, setCompany] = useState(null);
  const [role, setRole] = useState(null);
  const [loading, setLoading] = useState(true);

  const loadRole = async () => {
    try {
      setLoading(true);

      const res = await fetch(
        `${API_BASE}/api/companies/${encodeURIComponent(decodedCompanyName)}`
      );

      const data = await res.json();
      const companyData = data.company || null;
      const roles = companyData?.roles || [];

      setCompany(companyData);
      setRole(roles[roleIndex] || null);
    } catch (err) {
      setCompany(null);
      setRole(null);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    loadRole();
  }, [decodedCompanyName, roleId]);

  const skills = role?.skills || [];
  const locations = role?.locations || [];

  const prep = useMemo(() => {
    return getPrepSuggestion(role?.roleName, skills);
  }, [role?.roleName, skills]);

  const youtubeResources = useMemo(() => {
    return getYoutubeResources(role?.roleName, skills);
  }, [role?.roleName, skills]);

  if (loading) {
    return (
      <div className="sy-page-theme sy-role-practice-theme min-h-screen bg-gradient-to-br from-slate-50 via-indigo-50/60 to-violet-50 px-6 py-8">
        <div className="rounded-[32px] bg-white p-8 font-black text-indigo-700 shadow-xl shadow-indigo-100 ring-1 ring-indigo-100">
          Loading role detail...
        </div>
      </div>
    );
  }

  if (!role) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-50 via-indigo-50/60 to-violet-50 px-6 py-8">
        <button
          onClick={() => navigate("/companies")}
          className="mb-6 rounded-2xl bg-white px-5 py-3 font-black text-slate-700 shadow-sm ring-1 ring-slate-200"
        >
          ← Back to Companies
        </button>

        <div className="rounded-[32px] bg-red-50 p-8 font-black text-red-700 ring-1 ring-red-100">
          Role not found in dataset.
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-50 via-indigo-50/60 to-violet-50 px-6 py-8">
      <button
        onClick={() => navigate("/companies")}
        className="mb-6 rounded-2xl bg-white px-5 py-3 font-black text-slate-700 shadow-sm ring-1 ring-slate-200 transition hover:bg-indigo-50 hover:text-indigo-700"
      >
        ← Back to Companies
      </button>

      <section className="relative overflow-hidden rounded-[38px] bg-gradient-to-br from-[#0f172a] via-[#312e81] to-[#6d28d9] p-8 text-white shadow-2xl shadow-indigo-200">
        <div className="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-indigo-400/25 blur-3xl" />
        <div className="absolute -bottom-28 left-20 h-80 w-80 rounded-full bg-cyan-400/10 blur-3xl" />

        <div className="relative z-10">
          <p className="text-xs font-black uppercase tracking-[0.35em] text-indigo-200">
            Dataset Based Role Preparation
          </p>

          <h1 className="mt-3 text-4xl font-black tracking-tight md:text-5xl">
            {role.roleName}
          </h1>

          <p className="mt-4 max-w-4xl text-sm font-semibold leading-6 text-indigo-100">
            Company: {company?.companyName || decodedCompanyName}. Follow this simple preparation plan to understand what to study first.
